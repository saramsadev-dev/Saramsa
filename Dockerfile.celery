# Celery worker application image.
# Uses the pre-built base image (Dockerfile.celery-base) for fast builds.
# Only rebuilds when application code changes (~2-3 min).

ARG BASE_IMAGE=saramsa/saramsa-celery-base:latest

FROM ${BASE_IMAGE}

WORKDIR /app

# Copy backend code (includes celery_ops/ inside backend/)
COPY backend/ ./

# Skip collectstatic — Celery workers don't serve static files

EXPOSE 8000

CMD ["python", "start_celery.py"]
