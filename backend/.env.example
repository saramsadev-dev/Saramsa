APPLICATIONINSIGHTS_CONNECTION_STRING="your-app-insights-connection-string"
SECRET_KEY='your-django-secret-key'

# Azure OpenAI (required by openai_client.py – must use these names)
AZURE_ENDPOINT_URL="https://your-openai.cognitiveservices.azure.com/"
AZURE_DEPLOYMENT_NAME="gpt-5-mini"
AZURE_API_KEY="your-azure-openai-key"
AZURE_API_VERSION="2025-04-01-preview"

JIRA_EMAIL="your-jira-email"
JIRA_API_TOKEN="your-jira-api-token"
JIRA_DOMAIN="your-domain.atlassian.net"
JIRA_PROJECT_KEY="SCRUM"

AZURE_DEVOPS_ORGANIZATION="your-org"
AZURE_DEVOPS_PROJECT="your-project"
AZURE_DEVOPS_PAT="your-devops-pat"

# Neon PostgreSQL Database
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Local Redis (use when running Redis on Windows/WSL)
# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/1
# CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Azure Redis Cache (SSL, port 6380) – cache, Celery broker, and result backend
REDIS_URL=rediss://:your-redis-key@your-redis-host.redis.cache.windows.net:6380/?ssl_cert_reqs=CERT_NONE
CELERY_BROKER_URL=rediss://:your-redis-key@your-redis-host.redis.cache.windows.net:6380/?ssl_cert_reqs=CERT_NONE
CELERY_RESULT_BACKEND=rediss://:your-redis-key@your-redis-host.redis.cache.windows.net:6380/?ssl_cert_reqs=CERT_NONE

# Flower Configuration (optional)
FLOWER_BASIC_AUTH=admin:password123

# LLM concurrency: max concurrent API calls per analysis (default 8). Tune per Azure OpenAI TPM/RPM.
LLM_MAX_CONCURRENT_REQUESTS=8

# Local ML Pipeline Configuration
USE_LOCAL_PIPELINE=true

DEBUG=False
# Set true so GET /api/schema/ is registered (e.g. production API registry sync / CI). Swagger UI remains DEBUG-only.
ENABLE_OPENAPI_SCHEMA=false
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
TEST_USER_EMAIL=test.user@saramsa.local
TEST_USER_PASSWORD=your-test-password
LOGIN_EMAIL=test.user@saramsa.local
LOGIN_PASSWORD=your-test-password
REGISTRATION_OTP_BYPASS=false

# Linear API (Project Management)
LINEAR_API_KEY=your-linear-api-key

# Azure Communication Services Email
EMAIL_BACKEND=authentication.email_backend.AzureEmailBackend
AZURE_EMAIL_CONNECTION_STRING=endpoint=https://your-comm.communication.azure.com/;accesskey=your-key
DEFAULT_FROM_EMAIL=DoNotReply@your-domain.azurecomm.net

# Slack Source Connector (OAuth App)
BACKEND_BASE_URL=https://your-backend-url.azurewebsites.net
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_REDIRECT_URI=https://your-redirect-url/api/integrations/slack/oauth/callback/

# Stripe Billing (Subscriptions)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_DEFAULT_PRICE_ID=price_xxx
