# ============================================
# Django Core Configuration
# ============================================

# Django Secret Key - REQUIRED
# Generate a new secret key for production: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-your-secret-key-here-change-in-production

# Debug Mode - Set to False in production
DEBUG=True

# Allowed Hosts - Comma-separated list of hostnames
# For Azure: .azurewebsites.net will be automatically added
ALLOWED_HOSTS=.azurewebsites.net,127.0.0.1,localhost

# ============================================
# Azure Application Insights / OpenTelemetry
# ============================================

# Azure Application Insights Connection String
# Format: InstrumentationKey=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx;IngestionEndpoint=https://...
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=00000000-0000-0000-0000-000000000000

# Azure Website Name (for OpenTelemetry service name)
WEBSITE_SITE_NAME=saramsa-backend

# Environment (development, staging, production)
ENVIRONMENT=development

# Application Version
APP_VERSION=1.0.0

# Hostname (for service instance ID)
HOSTNAME=localhost

# ============================================
# Cosmos DB Configuration - REQUIRED
# ============================================

# Cosmos DB Endpoint URL
COSMOS_DB_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/

# Cosmos DB Primary Key
COSMOS_DB_KEY=your-cosmos-db-key

# Database Name
COSMOS_DB_DATABASE=saramsa-db

# Container Names (optional - defaults shown)
COSMOS_DB_USERS_CONTAINER=users
COSMOS_DB_ANALYSIS_CONTAINER=analysis
COSMOS_DB_UPLOADS_CONTAINER=uploads
COSMOS_DB_USER_STORIES_CONTAINER=user_stories
COSMOS_DB_PROJECTS_CONTAINER=projects
COSMOS_DB_USER_DATA_CONTAINER=user_data
COSMOS_DB_INTEGRATIONS_CONTAINER=integrations

# ============================================
# AI/LLM Configuration - REQUIRED
# ============================================

# Azure OpenAI Endpoint URL
ENDPOINT_URL=https://your-openai-resource.openai.azure.com/

# Azure OpenAI Deployment Name
DEPLOYMENT_NAME=gpt-4

# Azure OpenAI API Key
API_KEY=your-azure-openai-api-key

# Azure OpenAI API Version
API_VERSION=2024-02-15-preview

# ============================================
# AI Prompts Configuration
# ============================================


PROMPTS_JSON={"default": {"sentiment": "You are a program manager analysing customer feedback for Some Website.\n        Analyze the following feedback:\n <feedback_data>\n        Generate a **summary report** in JSON format with the following key insights from my client's point of view:\n\n        1. **Overall sentiment**: Provide the positive, negative, and neutral percentages for the client's feedback.\n        2. **Feature-based sentiment analysis**: \n            - Classify the feedback into the following features: features. \n            - Provide the overall sentiment for each feature, for example, \"product quality: 70% positive, 20% negative, 10% neutral\".\n            - Include a concise description for each feature summarizing what users say.\n            - Include feature-specific keywords that align with that feature.\n            - Include the count of comments that mention each feature.\n        3. **Consolidated keywords for wordclouds**: \n            - List the most common **positive** and **negative** keywords that represent feedback for the features. These will be used for word clouds.\n        \n        Structure the output as:\n        {\n        \"counts\": {\"total\": n, \"positive\":n, \"negative\":n, \"neutral\":n},\n        \"sentiment_summary\": { \"positive\": X%, \"negative\": Y%, \"neutral\": Z% },\n        \"feature_asba\": [\n            { \"feature\": \"product quality\", \"description\": \"Short summary of what users say about product quality.\", \"sentiment\": { \"positive\": 60%, \"negative\": 20%, \"neutral\": 20% }, \"keywords\" : [\"durable\", \"fragile\", \"build quality\"], \"comment_count\": 15 },\n            { \"feature\": \"customer service\", \"description\": \"Short summary of what users say about support.\", \"sentiment\": { \"positive\": 43%, \"negative\": 40%, \"neutral\": 17% }, \"keywords\" : [\"response time\", \"SLA\", \"helpful\"], \"comment_count\": 12 },\n            { \"feature\": \"pricing\", \"description\": \"Short summary of what users say about pricing.\", \"sentiment\": { \"positive\": 30%, \"negative\": 60%, \"neutral\": 10% }, \"keywords\" : [\"expensive\", \"value\", \"discount\"], \"comment_count\": 8 }\n        ],\n        \"positive_keywords\": [\n            { \"keyword\": \"quality\", \"sentiment\": 0.8 },\n            { \"keyword\": \"service\", \"sentiment\": 0.6 }\n        ],\n        \"negative_keywords\": [\n            { \"keyword\": \"delay\", \"sentiment\": 0.9 },\n            { \"keyword\": \"expensive\", \"sentiment\": 0.7 }\n        ]\n        }\n        \n        **Important**: Use \"comment_count\" (with underscore) as the field name for the number of comments per feature.", "deep_analysis": "You are a product program manager reviewing customer feedback for Some Website. Based on the feedback data provided, extract detailed, actionable insights to help the development team prioritize improvements.\n\n<feedback_data>\n\nYour job is to:\n1. Analyze the feedback to identify specific issues, feature requests, and improvements needed\n2. Create work items that can be directly imported into {platform_name} based on the available issue types\n3. Categorize items appropriately based on their nature (bug, task, feature, change, etc.)\n\nReturn the output in the following structured JSON format:\n\n{\n  \"work_items\": [\n    {\n      \"type\": \"bug|task|feature|change|epic|story\",\n      \"title\": \"Clear, actionable title\",\n      \"description\": \"Detailed description of the work item (2-4 sentences)\",\n      \"priority\": \"critical|high|medium|low\",\n      \"{tag_field}\": [\"tag1\", \"tag2\", \"tag3\"],\n      \"acceptance_criteria\": \"What needs to be done to complete this item\",\n      \"business_value\": \"Why this item is important\",\n      \"effort_estimate\": \"Story points or time estimate\",\n      \"feature_area\": \"Which feature this relates to\"\n    }\n  ],\n  \"summary\": {\n    \"total_items\": 10,\n    \"by_type\": {\n      \"bug\": 3,\n      \"task\": 4,\n      \"feature\": 2,\n      \"change\": 1\n    },\n    \"by_priority\": {\n      \"critical\": 2,\n      \"high\": 4,\n      \"medium\": 3,\n      \"low\": 1\n    }\n  }\n}\n\nGuidelines for work item creation:\n- bug: Something that's broken or not working as expected\n- feature: New functionality that users are requesting\n- task: General work that needs to be done\n- change: Enhancements to existing features or improvements\n- epic: Large initiatives that contain multiple related items\n- story: User-focused features or requirements\n\nPriority guidelines:\n- critical: System-breaking issues, security vulnerabilities\n- high: Major user-impacting issues, core features\n- medium: Important improvements, nice-to-have features\n- low: Minor improvements, documentation updates\n\nOnly return valid JSON with no explanation or commentary."}}

# ============================================
# Azure DevOps Integration - Optional
# ============================================

# Azure DevOps Organization Name
AZURE_DEVOPS_ORGANIZATION=your-org-name

# Azure DevOps Project Name
AZURE_DEVOPS_PROJECT=your-project-name

# Azure DevOps Personal Access Token (PAT)
# Create at: https://dev.azure.com/{org}/_usersSettings/tokens
AZURE_DEVOPS_PAT=your-azure-devops-pat-token

# ============================================
# Jira Integration - Optional
# ============================================

# Jira Email/Username
JIRA_EMAIL=your-email@example.com

# Jira API Token
# Create at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your-jira-api-token

# Jira Domain (e.g., yourcompany.atlassian.net)
JIRA_DOMAIN=yourcompany.atlassian.net

# Jira Project Key (e.g., PROJ)
JIRA_PROJECT_KEY=PROJ

# ============================================
# Azure Log Analytics - Optional
# ============================================

# Log Analytics Workspace ID
LOG_ANALYTICS_WORKSPACE_ID=your-workspace-id

# Log Analytics Shared Key
LOG_ANALYTICS_SHARED_KEY=your-shared-key

# Log Analytics Endpoint (optional, defaults to standard endpoint)
LOG_ANALYTICS_ENDPOINT=https://your-workspace-id.ods.opinsights.azure.com/api/logs?api-version=2016-04-01

# ============================================
# Middleware Configuration - Optional
# ============================================

# Enable request body logging (true/false)
LOG_REQUEST_BODIES=false

# Slow request threshold in milliseconds
SLOW_REQUEST_MS=1000