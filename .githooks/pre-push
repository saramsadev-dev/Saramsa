#!/usr/bin/env bash
set -uo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

to_win_path() {
  if command -v cygpath >/dev/null 2>&1; then
    cygpath -w "$1"
  else
    echo "$1" | sed 's|^/\([a-zA-Z]\)/|\1:\\|' | sed 's|/|\\|g'
  fi
}

PYTHON_CMD=""
if [ -x "$ROOT_DIR/backend/venv/Scripts/python.exe" ]; then
  PYTHON_CMD="$ROOT_DIR/backend/venv/Scripts/python.exe"
elif command -v python3 >/dev/null 2>&1; then
  PYTHON_CMD="python3"
else
  PYTHON_CMD="python"
fi

echo "Running API registry sync + tests before push..."

cd "$ROOT_DIR/backend"

ERRORS=""
FAILED=0

SYNC_OUTPUT=$("$PYTHON_CMD" scripts/sync_api_registry_from_swagger.py 2>&1) || {
  FAILED=1
  ERRORS+="=== sync_api_registry_from_swagger.py FAILED ==="$'\n'"$SYNC_OUTPUT"$'\n\n'
}

if [ $FAILED -eq 0 ]; then
  TEST_OUTPUT=$("$PYTHON_CMD" scripts/test_api_registry.py --notify-slack 2>&1) || {
    FAILED=1
    ERRORS+="=== test_api_registry.py FAILED ==="$'\n'"$TEST_OUTPUT"$'\n\n'
  }
fi

if [ $FAILED -ne 0 ]; then
  echo "$ERRORS"
  echo "Pre-push hook FAILED."
  if [ -z "${CI:-}" ]; then
    WIN_ROOT="$(to_win_path "$ROOT_DIR")"
    PROMPT_FILE="$ROOT_DIR/.pre-push-prompt.txt"
    {
      echo "The pre-push hook failed with the errors below."
      echo ""
      echo "YOUR TASK:"
      echo "1. Read the errors carefully."
      echo "2. If there are unconfigured endpoints in api-registry.json:"
      echo "   - Look at the corresponding Django view in backend/ to understand the response shape."
      echo "   - Set 'enabled': true for each endpoint."
      echo "   - Set the correct 'expected_status' (200, 201, 204, etc.)."
      echo "   - Set 'expect_json_keys' to match the actual response keys."
      echo "   - Add a 'body' object if the method is POST/PUT/PATCH and requires a request body."
      echo "   - Remove the 'discovered': true flag to mark it as configured."
      echo "3. If there are SCHEMA CHANGED warnings:"
      echo "   - The Swagger spec for that endpoint changed (params, request body, or response)."
      echo "   - Check the Django view to see what changed."
      echo "   - Update 'expected_status', 'expect_json_keys', and 'body' in api-registry.json if needed."
      echo "   - Remove the 'schema_changed' and 'prev_schema_hash' flags once verified."
      echo "4. If there are test failures, fix the underlying code or registry config."
      echo "4. Re-run both scripts to verify:"
      echo "   cd backend"
      echo "   python scripts/sync_api_registry_from_swagger.py"
      echo "   python scripts/test_api_registry.py --notify-slack"
      echo ""
      echo "=== ERRORS ==="
      echo "$ERRORS"
    } > "$PROMPT_FILE"
    WIN_PROMPT="$(to_win_path "$PROMPT_FILE")"
    powershell.exe -Command "Start-Process powershell -ArgumentList '-NoExit','-Command',\"cd ''$WIN_ROOT''; \`$env:TERM=''xterm-256color''; codex --yolo (Get-Content -Raw ''$WIN_PROMPT'')\""
  fi
  exit 1
fi

echo "API registry tests passed."
