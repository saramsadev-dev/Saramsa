#!/usr/bin/env bash
set -uo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

PYTHON_CMD=""
if [ -x "$ROOT_DIR/backend/venv/Scripts/python.exe" ]; then
  PYTHON_CMD="$ROOT_DIR/backend/venv/Scripts/python.exe"
elif command -v python3 >/dev/null 2>&1; then
  PYTHON_CMD="python3"
else
  PYTHON_CMD="python"
fi

echo "Running API registry sync + tests before push..."

cd "$ROOT_DIR/backend"

ERRORS=""
FAILED=0

# Only run backend API registry checks when backend files are part of this push.
BACKEND_CHANGED=0
if git rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1; then
  if git diff --name-only '@{u}'..HEAD | grep -q '^backend/'; then
    BACKEND_CHANGED=1
  fi
else
  # No upstream configured yet; run checks to stay safe.
  BACKEND_CHANGED=1
fi

if [ "$BACKEND_CHANGED" -eq 0 ]; then
  echo "No backend changes detected; skipping API registry sync/tests."
  exit 0
fi

SYNC_OUTPUT=$("$PYTHON_CMD" scripts/sync_api_registry_from_swagger.py 2>&1) || {
  FAILED=1
  ERRORS+="=== sync_api_registry_from_swagger.py FAILED ==="$'\n'"$SYNC_OUTPUT"$'\n\n'
}

if [ $FAILED -eq 0 ]; then
if [ -f "scripts/test_api_registry.py" ]; then
  TEST_OUTPUT=$("$PYTHON_CMD" scripts/test_api_registry.py --notify-slack 2>&1) || {
    FAILED=1
    ERRORS+="=== test_api_registry.py FAILED ==="$'\n'"$TEST_OUTPUT"$'\n\n'
  }
else
  echo "WARNING: backend/scripts/test_api_registry.py not found, skipping API registry tests in pre-push hook."
fi
fi

if [ $FAILED -ne 0 ]; then
  echo "$ERRORS"
  echo "Pre-push hook FAILED."
  echo "Fix the reported issues and re-run:"
  echo "  cd backend"
  echo "  python scripts/sync_api_registry_from_swagger.py"
  echo "  python scripts/test_api_registry.py --notify-slack"
  exit 1
fi

echo "API registry tests passed."
